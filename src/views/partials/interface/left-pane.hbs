<div class="left-pane-wrapper" id="left-pane-wrapper">
  <button
    type="button"
    class="left-pane__logo-trigger"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="left-pane"
    id="left-pane-logo-trigger"
    data-left-pane-toggle
  >
    {{> svg/logo}}
  </button>
  <aside class="left-pane" id="left-pane" role="navigation" aria-label="Main menu">
    <nav class="left-pane__nav">
      <ul class="left-pane__menu">
        General
        <li>
          <a href="/"><span class="has-text-primary">-</span> Main page</a>
        </li>
        {{!-- <li>
          <a href="/my-points"><span class="has-text-primary">-</span> My points</a>
        </li> --}}
        <li>
          <a href="/my-collections"><span class="has-text-primary">-</span> My collections</a>
        </li>
        <li>
          <a href="/my-categories"><span class="has-text-primary">-</span> My categories</a>
        </li>
        <li>
          <a href="/my-items"><span class="has-text-primary">-</span> My items</a>
        </li>
      {{#if viewData.userIsAdmin}}
      <p>Admin console</p>
        <li>
          <a href="/users"><span class="has-text-primary">-</span> Users</a>
        </li>
      {{/if}}

      <li class="left-pane__dropdown">
        <button
          type="button"
          class="left-pane__trigger"
          aria-expanded="false"
          aria-controls="left-pane-more-menu"
          id="left-pane-more-trigger"
          data-dropdown-trigger
        >
          More
        </button>
        <ul
          id="left-pane-more-menu"
          class="left-pane__dropdown-menu"
          role="menu"
          aria-labelledby="left-pane-more-trigger"
        >
          <li role="none"><a href="/about" role="menuitem"><span class="has-text-primary">-</span> About</a></li>
          <li role="separator" class="left-pane__dropdown-divider"></li>
          <li role="none">
            <a href="https://github.com/KorneAlex/Feedjibacki/issues" target="_blank" rel="noopener noreferrer" role="menuitem"><span class="has-text-primary">-</span> Report an issue</a>
          </li>
          <li role="none"><a href="/test" role="menuitem"><span class="has-text-primary">-</span> Test</a></li>
        </ul>
      </li>
    </ul>
    </nav>
</aside>
</div>

<script>
(function () {
  let wrapper = document.getElementById('left-pane-wrapper');
  let pane = document.querySelector('.left-pane');
  let logoTrigger = document.querySelector('[data-left-pane-toggle]');
  let dropdownTrigger = pane && pane.querySelector('[data-dropdown-trigger]');
  let dropdownMenu = dropdownTrigger && pane.querySelector('#' + (dropdownTrigger.getAttribute('aria-controls') || ''));

  if (!wrapper || !pane || !logoTrigger) return;

  function openPane() {
    wrapper.classList.add('is-open');
    logoTrigger.setAttribute('aria-expanded', 'true');
    logoTrigger.setAttribute('aria-label', 'Close menu');
  }

  function closePane() {
    wrapper.classList.remove('is-open');
    logoTrigger.setAttribute('aria-expanded', 'false');
    logoTrigger.setAttribute('aria-label', 'Open menu');
    if (dropdownTrigger && dropdownMenu) {
      dropdownTrigger.setAttribute('aria-expanded', 'false');
      dropdownMenu.removeAttribute('data-open');
      dropdownMenu.setAttribute('hidden', '');
    }
  }

  function togglePane() {
    if (wrapper.classList.contains('is-open')) closePane();
    else openPane();
  }

  logoTrigger.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();
    togglePane();
  });

  document.addEventListener('click', function (e) {
    if (wrapper.classList.contains('is-open') && !wrapper.contains(e.target)) {
      closePane();
    }
  });

  if (dropdownTrigger && dropdownMenu) {
    function openDropdown() {
      dropdownTrigger.setAttribute('aria-expanded', 'true');
      dropdownMenu.setAttribute('data-open', '');
      dropdownMenu.removeAttribute('hidden');
    }
    function closeDropdown() {
      dropdownTrigger.setAttribute('aria-expanded', 'false');
      dropdownMenu.removeAttribute('data-open');
      dropdownMenu.setAttribute('hidden', '');
    }
    function toggleDropdown() {
      if (dropdownTrigger.getAttribute('aria-expanded') === 'true') closeDropdown();
      else openDropdown();
    }
    dropdownTrigger.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      toggleDropdown();
    });
    document.addEventListener('click', function (e) {
      if (dropdownTrigger.getAttribute('aria-expanded') === 'true' && !pane.contains(e.target)) {
        closeDropdown();
      }
    });
  }
})();
</script>
