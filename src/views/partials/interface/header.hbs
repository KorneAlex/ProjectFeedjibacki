          </a>
        </div>
      </div>
      {{!-- {{#unless viewData.title}}
      <div>
        <a href="/signup" class="button is-primary ml-4">
          Sign up
        </a>
        <a href="/login" class="button is-light ml-2">
          Log in
        </a>
      </div>
      {{/unless}} --}}
    </div>

    <div class="navbar-end">
      {{> interface/account-menu}}
    </div>
  </div>
