<nav class="navbar" role="navigation" aria-label="main navigation">
  {{#if viewData.title}}
  <div class="navbar-page-header">
    <h1 class="navbar-page-title title is-2 mb-0">{{viewData.title}}</h1>
    {{#if viewData.subtitle}}
    <p class="navbar-page-subtitle">{{viewData.subtitle}}</p>
    {{/if}}
  </div>
  {{/if}}
  <div class="navbar-brand">
    {{!-- <a class="navbar-item" href="/">
      {{> svg/logo}}
    </a> --}}
    <div class="navbar-item" style="width: 4.5rem;">{{> interface/left-pane}}</div>
    <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbarBasicExample">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </a>
  </div>

  <div id="navbarBasicExample" class="navbar-menu">
    <div class="navbar-start">
      <a href="/" class="navbar-item" style="z-index: 1000;">
        {{!-- {{> svg/logo-text}} --}}
        {{> svg/feedjibacki}}
      </a>
      {{#if viewData.isAuthenticated}}
      {{!-- <a href="/map" class="navbar-item">
        Feedback map
      </a> --}}
      {{#if viewData.userIsAdmin }}
      <a href="/users" class="navbar-item">
        Users
      </a>
      {{/if}}
      {{/if}}
      <div class="navbar-item has-dropdown is-hoverable">
        <a class="navbar-link">
