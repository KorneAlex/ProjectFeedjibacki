<form
  id="create-collection-form"
  class="box mb-5"
  action="/collections/create"
  method="POST"
  name="create-collection-form"
  autocomplete="on"
>
  <h2 class="title is-5 mb-2">Create a collection</h2>
  <p class="subtitle is-6 has-text-grey mb-4">Collections group your items. Choose a name, privacy level, and optional items.</p>

  {{#if viewData.infoMessage}}
    <p class="help {{viewData.infoClass}} mb-4">{{viewData.infoMessage}}</p>
  {{/if}}

  <div class="field">
    <label class="label" for="collection-name">Name</label>
    <div class="control">
      <input
        id="collection-name"
        class="input"
        type="text"
        name="name"
        placeholder="e.g. Lidl favourites"
        required
        minlength="2"
        maxlength="100"
      />
    </div>
  </div>

  <div class="field">
    <label class="label" for="collection-privacy">Privacy</label>
    <div class="control">
      <div class="select is-fullwidth">
        <select id="collection-privacy" name="privacy">
          <option value="private" selected>Private</option>
          <option value="shared">Shared</option>
        </select>
      </div>
    </div>
  </div>

  {{#if viewData.items.length}}
    <fieldset class="mb-4">
      <legend class="label mb-3">Items in this collection</legend>
      <div class="collection-item-checkboxes">
        {{#each viewData.items}}
          <label class="checkbox collection-item-checkboxes__label">
            <input type="checkbox" name="item_ids" value="{{this._id}}" />
            {{this.data.name}}
          </label>
        {{/each}}
      </div>
    </fieldset>
  {{else}}
    <p class="help mb-4">You have no items yet. You can add items to this collection later from the collection page or when creating items.</p>
  {{/if}}

  <div class="field is-grouped">
    <div class="control">
      <button class="button is-primary" type="submit">Create collection</button>
    </div>
  </div>
</form>
