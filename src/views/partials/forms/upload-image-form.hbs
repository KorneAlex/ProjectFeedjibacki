{{#if viewData.uploadFeedback}}
  <p class="{{viewData.uploadFeedback.class}} mb-3">{{viewData.uploadFeedback.text}}</p>
{{/if}}
{{#if viewData.pointData}}
<form action="/point/uploadImage?id={{viewData.pointData._id}}" method="POST" enctype="multipart/form-data">
{{else if viewData.item}}
<form action="/items/uploadImage?id={{viewData.item._id}}" method="POST" enctype="multipart/form-data">
{{/if}}
  <div class="file has-name is-fullwidth upload-image-form__picker">
    <label class="file-label">
      <input class="file-input" name="imagefile" type="file" accept="image/png, image/jpeg">
      <span class="file-cta">
        <span class="file-icon">
          <i class="fas fa-upload"></i>
        </span>
        <span class="file-label">Choose a file…</span>
      </span>
      <span class="file-name"></span>
    </label>
    <button type="submit" class="button is-info">Upload</button>
  </div>
</form>
