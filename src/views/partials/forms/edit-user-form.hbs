<form
  class="box mb-5"
  action="/user/{{viewData.userId}}/edit"
  method="POST"
  name="edit-user-form"
  autocomplete="on"
>
  <h2 class="title is-5 mb-2">Edit user</h2>

  {{#if viewData.infoMessage}}
    <p class="help {{viewData.infoClass}} mb-4">{{viewData.infoMessage}}</p>
  {{/if}}

  <div class="field">
    <label class="label" for="edit-user-username">Username</label>
    <div class="control">
      <input
        id="edit-user-username"
        class="input"
        type="text"
        name="username"
        value="{{viewData.userData.metadata.username}}"
        required
        minlength="2"
        maxlength="20"
        pattern="[A-Za-z0-9]+"
      />
    </div>
  </div>

  <div class="field">
    <label class="label" for="edit-user-email">Email</label>
    <div class="control">
      <input
        id="edit-user-email"
        class="input"
        type="email"
        name="email"
        value="{{viewData.userData.metadata.email}}"
        required
      />
    </div>
  </div>

  <div class="field">
    <label class="checkbox">
      <input
        type="checkbox"
        name="isAdmin"
        value="true"
        {{#if viewData.userData.metadata.isAdmin}}checked{{/if}}
      />
      Administrator
    </label>
  </div>

  <div class="field is-grouped mt-5">
    <div class="control">
      <button class="button is-primary" type="submit">Save</button>
    </div>
    <div class="control">
      <a class="button is-light" href="/user?userid={{viewData.userId}}">Cancel</a>
    </div>
  </div>
</form>
