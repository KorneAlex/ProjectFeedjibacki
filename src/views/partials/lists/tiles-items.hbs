{{#if viewData.activeCategoryFilter}}
  <p class="has-text-grey is-size-7 mb-2">
    <a href="/my-items" class="has-text-primary">&larr; All items</a>
  </p>
  <h2 class="title is-5 mb-4">Category: {{viewData.activeCategoryFilter}}</h2>
  <div class="items-grid">
    {{> lists/add-item-tile }}
    {{#each viewData.items}}
      {{> lists/item-tile }}
    {{/each}}
  </div>
  {{#unless viewData.items.length}}
    <p class="help has-text-grey mt-3 mb-0">No other items in this category yet.</p>
  {{/unless}}
{{else}}
  <h2 class="title is-5 mb-4">Your items</h2>
  <div class="items-grid">
    {{> lists/add-item-tile }}
    {{#each viewData.items}}
      {{> lists/item-tile }}
    {{/each}}
  </div>
  {{#unless viewData.items.length}}
    <p class="help has-text-grey mt-3 mb-0">Click the first tile to add your first item.</p>
  {{/unless}}
{{/if}}
