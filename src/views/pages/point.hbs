  {{#if viewData.message }}
<div style="text-align: center; margin-bottom: 2rem;">
    <p class="has-text-danger">{{ viewData.message }}</p>
</div>
{{/if}}

{{#if viewData.pointData }}


<style>
    .point__summary--element {
        width: 500px; 
        {{!-- border-style: solid; --}}
        border-radius: 4px;
        border-color: red;
    }
    .point__summary--header {
        background-color: var(--bulma-primary-dark);
        padding-left: 10px;
        margin-bottom: 5px;
        border-radius: 10px;
    }
    .point__summary--info,
    .card-content.point__summary--info {
        padding-left: 10px;
    }
    .point__summary--info p {
        margin-bottom: 0.25em;
    }
    @media only screen and (max-width: 600px){
    .point__summary--element {
        width: 100%;
    }

    .fullwidth__mobile {
        width: 100%;
    }
    }
</style>

<section class="is-flex is-flex-direction-column is-justify-content-center is-justify-content-space-around is-flex-wrap-wrap" style="margin-bottom: 2rem;">
    <div class="point__summary--element">

    {{!-- <div class="p-2">
        <div class="is-flex is-flex-direction-row">
            <div class="card-header-title point__summary--header">Where you bought it</div>
            <div class="card-header-icon"> </div>
        </div>
        <div class="point__summary--info card-content">
            <p>Longitude: {{ viewData.pointData.pos.lon }}</p>
            <p>Latitude: {{ viewData.pointData.pos.lat }}</p>
        </div>
    </div> --}}

    <div class="p-2">
        <div class="is-flex is-flex-direction-row">
            <div class="card-header-title point__summary--header">Feedback</div>
            <div class="card-header-icon"></div>
        </div>
        <div class="card-content point__summary--info">
            <p>{{ viewData.pointData.data.description }}</p>
        </div>
    </div>

    <div class="p-2">
        <div class="is-flex is-flex-direction-row">
            <div class="card-header-title point__summary--header">Product category: {{ viewData.pointData.data.categories.length }}</div>
            <div class="card-header-icon"></div>
        </div>
        <div class="is-flex is-flex-direction-row card-content point__summary--info">
            {{#each viewData.pointData.data.categories }}
            <p>{{this}}&nbsp;</p>
            {{/each}}
        </div>
    </div>

    <div class="p-2">
        <div class="is-flex is-flex-direction-row">
            <div class="card-header-title point__summary--header">Purchased / recorded on</div>
            <div class="card-header-icon"></div>
        </div>
        <div class="card-content point__summary--info">
            <p>{{ viewData.pointData.time.created }}</p>
        </div>
    </div>
    </div>
    {{>forms/upload-image}}
</section>

{{/if}}