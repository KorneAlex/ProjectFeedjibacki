<div class="page-content">
  <div class="container container--wide">
    {{> forms/create-collection-form }}
    {{> lists/tiles-collection }}
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tile = document.getElementById("add-collection-tile");
    const panel = document.getElementById("create-collection-panel");
    if (!tile || !panel) return;

    function showCreateCollectionPanel() {
      panel.style.display = "";
      panel.scrollIntoView({ behavior: "smooth", block: "start" });
      const nameInput = document.getElementById("collection-name");
      if (nameInput) nameInput.focus();
    }

    tile.addEventListener("click", showCreateCollectionPanel);
    tile.addEventListener("keydown", function (event) {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        showCreateCollectionPanel();
      }
    });

    if (window.location.hash === "#create-collection-form") {
      showCreateCollectionPanel();
    }
  });
</script>
