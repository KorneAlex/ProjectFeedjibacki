<div style="text-align: center; margin-bottom: 2rem;">
  <div class="title is-2 pt-5 mb-0"><span>User {{ viewData.userData.username }}</span></div> 
    <p>{{ viewData.userData._id }}</p>
</div>

{{!-- TODO: rename this styles --}}
<style>
    .point__summary--element {
        width: 500px; 
        {{!-- border-style: solid; --}}
        border-radius: 4px;
        border-color: red;
    }
    .point__summary--header {
        background-color: var(--bulma-primary-dark);
        padding-left: 10px;
        margin-bottom: 5px;
        border-radius: 10px;
    }
    .point__summary--info,
    .card-content.point__summary--info {
        padding-left: 10px;
    }
    .point__summary--info p {
        margin-bottom: 0.25em;
    }
    @media only screen and (max-width: 600px){
    .point__summary--element {
        width: 100%;
    }

    .fullwidth__mobile {
        width: 100%;
    }
    }
</style>

<section class="is-flex is-flex-direction-column is-justify-content-center is-justify-content-space-around is-flex-wrap-wrap" style="margin-bottom: 2rem;">
    <div class="point__summary--element">

        <div class="p-2">
            <div class="is-flex is-flex-direction-row">
                <div class="card-header-title point__summary--header">Email</div>
                <div class="card-header-icon"></div>
            </div>
            <div class="card-content point__summary--info">
                <p>{{ viewData.userData.email }}</p>
            </div>
        </div>

        <div class="p-2">
            <div class="is-flex is-flex-direction-row">
                <div class="card-header-title point__summary--header">Account data</div>
                <div class="card-header-icon"></div>
            </div>
            <div class="card-content point__summary--info">
                <p>Admin: {{ viewData.userData.isAdmin }}</p>
                <p>Created on: {{ viewData.userData.time.created }}</p>
                <p>Account age: {{ viewData.userData.time.created }}</p>
                <p>Last login: {{ viewData.userData.time.lastLogin }}</p>
            </div>
        </div>

        <div class="p-2">
            <div class="is-flex is-flex-direction-row">
                <div class="card-header-title point__summary--header">Feedback entries</div>
                <div class="card-header-icon"></div>
            </div>
            <div class="card-content point__summary--info">
                <p>Feedback entries: {{ viewData.userData.points.length }}</p>
                <p>Unique categories: {{ viewData.extraData.uniqueCategories }}</p>
            </div>
        </div>

    </div>
</section>